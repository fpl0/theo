{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"includes": ["src/**", "tests/**", "*.json"]
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"globals": ["Bun"]
	},
	"linter": {
		"rules": {
			"a11y": "error",
			"complexity": "error",
			"correctness": {
				"recommended": true,
				"noNodejsModules": "off"
			},
			"performance": "error",
			"security": "error",
			"style": "error",
			"suspicious": {
				"recommended": true,
				"noConsole": "off"
			},
			"nursery": {
				"noFloatingPromises": "error"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
