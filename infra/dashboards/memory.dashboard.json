      "panels": [
        {
          "id": "Panel_mem_ops_time",
          "type": "area-stacked",
          "title": "Memory Operations Over Time",
          "description": "Node and episode operations by type",
          "config": {
            "show_legends": true,
            "decimals": 0,
            "unit": ""
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT histogram(_timestamp) as \"x_axis_1\", span_name, count(*) as \"y_axis_1\" FROM \"default\" WHERE service_name = 'theo' AND span_name IN ('store_node', 'search_nodes', 'get_node', 'store_episode', 'list_episodes', 'search_episodes') GROUP BY x_axis_1, span_name ORDER BY x_axis_1",
              "customQuery": true,
              "fields": {
                "stream": "default",
                "stream_type": "traces",
                "x": [],
                "y": [],
                "z": [],
                "breakdown": [],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": "",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
