        {
          "id": "Panel_llm_latency_pct",
          "type": "line",
          "title": "LLM Latency (p50 / p95 / p99)",
          "description": "Anthropic API call latency percentiles",
          "config": {
            "show_legends": true,
            "decimals": 2,
            "unit": "seconds"
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "histogram_quantile(0.5, rate(theo_llm_duration_bucket[5m]))",
              "customQuery": true,
              "fields": {
                "stream": "",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "breakdown": [],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": "p50",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            },
            {
              "query": "histogram_quantile(0.95, rate(theo_llm_duration_bucket[5m]))",
