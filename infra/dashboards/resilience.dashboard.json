{
  "version": 5,
  "title": "Theo Resilience",
  "description": "Circuit breaker, retry queue, health checks, event bus.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Default",
      "panels": [
        {
          "id": "Panel_res_queue",
          "type": "line",
          "title": "Retry Queue Depth",
          "description": "Current number of messages waiting for retry",
          "config": {
            "show_legends": false,
            "decimals": 0,
            "unit": ""
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "theo_resilience_queue_depth",
              "customQuery": true,
              "fields": {
                "stream": "",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "breakdown": [],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": "queue depth",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
            "y": 0,
            "w": 24,
            "h": 9,
            "i": 1
          },
          "htmlContent": "",
          "markdownContent": ""
        },
        {
          "id": "Panel_res_handler_errors",
          "type": "line",
          "title": "Bus Handler Errors",
          "description": "Handler failure rate by event type",
          "config": {
            "show_legends": true,
            "decimals": 2,
            "unit": ""
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "sum by (event_type)(rate(theo_bus_handler_errors_total[5m]))",
              "customQuery": true,
              "fields": {
                "stream": "",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "breakdown": [],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": "{event_type}",
