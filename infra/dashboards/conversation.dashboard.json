{
  "version": 5,
  "title": "Theo Conversation",
  "description": "Conversation loop: turns, tools, context assembly.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Default",
      "panels": [
        {
          "id": "Panel_conv_rate_speed",
          "type": "line",
          "title": "Turn Rate by Speed Tier",
          "description": "Conversation turns per second by LLM speed classification",
          "config": {
            "show_legends": true,
            "decimals": 2,
            "unit": ""
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "sum by (llm_speed)(rate(theo_conversation_turns_total[5m]))",
              "customQuery": true,
              "fields": {
                "stream": "",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "breakdown": [],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": "{llm_speed}",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
            "y": 0,
            "w": 24,
            "h": 9,
            "i": 1
          },
          "htmlContent": "",
          "markdownContent": ""
