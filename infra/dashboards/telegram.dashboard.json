{
  "version": 5,
  "title": "Theo Telegram",
  "description": "Telegram gate: message throughput, commands, ignored messages.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Default",
      "panels": [
        {
          "id": "Panel_tg_recv",
          "type": "metric",
          "title": "Messages Received",
          "description": "Total messages received from Telegram",
          "config": {
            "show_legends": false,
            "decimals": 0,
            "unit": ""
          },
          "queryType": "promql",
          "queries": [
            {
              "query": "sum(theo_telegram_messages_received_total)",
              "customQuery": true,
              "fields": {
                "stream": "",
                "stream_type": "metrics",
                "x": [],
                "y": [],
                "z": [],
                "breakdown": [],
                "filter": {
                  "filterType": "group",
                  "logicalOperator": "AND",
                  "conditions": []
                }
              },
              "config": {
                "promql_legend": "",
                "layer_type": "scatter",
                "weight_fixed": 1
              }
            }
          ],
          "layout": {
            "x": 0,
            "y": 0,
            "w": 12,
            "h": 5,
            "i": 1
          },
          "htmlContent": "",
          "markdownContent": ""
